APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Local: use +asyncpg for FastAPI async engine
DATABASE_URL=postgresql+asyncpg://etl_user:change_me@localhost:5432/etl_analytics
# Render: set DATABASE_URL from the Render Postgres dashboard (postgresql://...)
# The app auto-converts it to postgresql+asyncpg:// at startup
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
